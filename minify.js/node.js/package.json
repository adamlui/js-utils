{
  "name": "@adamlui/minify.js",
  "version": "2.5.2",
  "description": "Recursively minify all JavaScript files.",
  "author": {
    "name": "Adam Lui",
    "email": "adam@kudoai.com",
    "url": "https://github.com/adamlui"
  },
  "homepage": "https://github.com/adamlui/minify.js/tree/main/node.js/#readme",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "http://github.com/sponsors/adamlui"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/adamlui"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/adamlui"
    }
  ],
  "main": "dist/minify.min.js",
  "files": [
    "dist/",
    "docs/",
    "!docs/*/"
  ],
  "bin": {
    "minify-js": "dist/cli/index.js",
    "min-js": "dist/cli/index.js",
    "minifyjs": "dist/cli/index.js",
    "minjs": "dist/cli/index.js"
  },
  "scripts": {
    "test": "bash utils/testing/minify-cli.test.sh",
    "dev": "npm run build && npm i -g && minify-js --help",
    "build": "node utils/build",
    "build:js": "node utils/build --js",
    "build:data": "node utils/build --data",
    "build:json": "node utils/build --json",
    "debug": "node src/cli --debug",
    "bump:patch": "bash utils/bump.sh patch",
    "bump:minor": "bash utils/bump.sh minor",
    "bump:feat": "npm run bump:minor",
    "bump:major": "bash utils/bump.sh major",
    "lint": "eslint . --cache",
    "lint:all": "eslint .",
    "lint:fix": "eslint . --fix --cache",
    "lint:fix-all": "eslint . --fix",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamlui/minify.js.git"
  },
  "keywords": [
    "api",
    "cli",
    "compression",
    "files",
    "javascript",
    "js",
    "js-utils",
    "minifier",
    "uglifier",
    "utilities"
  ],
  "bugs": {
    "url": "https://github.com/adamlui/minify.js/issues"
  },
  "dependencies": {
    "console-table-printer": "^2.15.0",
    "is-unicode-supported": "^2.1.0",
    "node-clipboardy": "^1.0.3",
    "non-latin-locales": "^1.0.1",
    "uglify-js": "^3.19.3"
  },
  "devDependencies": {
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-regexp": "^3.1.0"
  }
}
