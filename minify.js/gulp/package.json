{
  "name": "gulp-minify.js",
  "version": "1.0.15",
  "description": "Gulp plug-in to recursively minify JavaScript files",
  "author": {
    "name": "Adam Lui",
    "email": "adam@kudoai.com",
    "url": "https://github.com/adamlui"
  },
  "homepage": "https://github.com/adamlui/minify.js/tree/main/gulp/#readme",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "http://github.com/sponsors/adamlui"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/adamlui"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/adamlui"
    }
  ],
  "main": "dist/gulp-minify.min.js",
  "files": [
    "dist/",
    "docs/"
  ],
  "scripts": {
    "dev": "npm run build && npm i -g",
    "build": "node utils/build",
    "bump:patch": "bash utils/bump.sh patch",
    "bump:minor": "bash utils/bump.sh minor",
    "bump:feat": "npm run bump:minor",
    "bump:major": "bash utils/bump.sh major",
    "lint": "eslint . --cache",
    "lint:all": "eslint .",
    "lint:fix": "eslint . --fix --cache",
    "lint:fix-all": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamlui/minify.js.git"
  },
  "keywords": [
    "api",
    "compression",
    "files",
    "gulpfriendly",
    "gulpplugin",
    "javascript",
    "js-utils",
    "js",
    "minifier",
    "utilities"
  ],
  "bugs": {
    "url": "https://github.com/adamlui/minify.js/issues"
  },
  "devDependencies": {
    "@adamlui/minify.js": "^2.5.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-regexp": "^3.1.0"
  }
}
