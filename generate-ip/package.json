    "@adamlui/minify.js": "^2.5.2",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-regexp": "^3.1.0"
  }
}
